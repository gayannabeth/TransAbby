{
	"Format": "2.9.0",
	"ConfigSchema": {
		// When false: dialogue only references depression, brief suicidal thoughts, and vague instances of transphobia
		// When true: dialogue references the above, as well as references to a previous suicide attempt, more explicit references to transphobia and transmisogyny, and references to transphobic/transmisogynistic violence
		"HeavierDialogue": {
			"AllowValues": "true, false",
			"Default": "false"
		},
		//Determines if Abigail can get female players pregnant BEFORE she gets her orchi done
		"AbigailCanImpregnateFemaleFarmer": {
			"AllowValues": "true, false",
			"Default": "false"
		}
	},
	"Changes": [
		{
			"LogName": "Trans Flag",
			"Action": "EditMap",
			"Target": "Maps/SeedShop",
			"FromFile": "assets/Maps/abby_trans_flag.tmx",
			"ToArea": {"X": 8, "Y": 1, "Width": 2, "Height": 1}
		},
		{
			"LogName": "Trans Flag",
			"Action": "EditMap",
			"Target": "Maps/spouseRooms",
			"FromFile": "assets/Maps/abby_trans_flag.tmx",
			"ToArea": {"X": 0, "Y": 0, "Width": 2, "Height": 1}
		},
		{
			"LogName": "Abigail Schedule Changes",
			"Action": "Include",
			"FromFile": "assets/schedules.json"
		},
		{
			"LogName": "Dialogue Changes",
			"Action": "Include",
			"FromFile": "assets/Dialogue/common.json"
		},
		{
			"LogName": "Dialogue Changes",
			"Action": "Include",
			"FromFile": "assets/Dialogue/heavy.json",
			"When": {
				"HeavierDialogue": "true"
			}
		},
		{
			"LogName": "Dialogue Changes",
			"Action": "Include",
			"FromFile": "assets/Dialogue/light.json",
			"When": {
				"HeavierDialogue": "false"
			}
		},
		{
			"LogName": "Pregnancy Changes",
			"Action": "Include",
			"FromFile": "assets/pregnancy.json"
		},
		{
			"LogName": "Events",
			"Action": "Include",
			"FromFile": "assets/Events/common.json"
		},
		{
			"LogName": "Events",
			"Action": "Include",
			"FromFile": "assets/Events/heavy.json",
			"When": {
				"HeavierDialogue": "true"
			}
		},
		{
			"LogName": "Events",
			"Action": "Include",
			"FromFile": "assets/Events/light.json",
			"When": {
				"HeavierDialogue": "false"
			}
		}
	]
